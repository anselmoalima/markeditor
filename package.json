{
  "name": "markmd-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "prepare": "husky",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "turbo run typecheck",
    "size": "turbo run size",
    "publint": "pnpm --filter markeditor publint",
    "attw": "pnpm --filter markeditor attw",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:config": "node --test tests/config.test.mjs tests/lint.test.mjs tests/changeset.test.mjs tests/ci.test.mjs tests/release.test.mjs tests/release-smoke.test.mjs",
    "check:workspaces": "pnpm m ls --json > /dev/null",
    "test:workspaces": "bash scripts/smoke-workspaces.sh",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "eslint": "^9",
    "js-yaml": "^4.1.0",
    "eslint-plugin-import-x": "^4",
    "eslint-plugin-jsx-a11y": "^6",
    "eslint-plugin-react": "^7",
    "eslint-plugin-react-hooks": "^5",
    "husky": "^9",
    "lint-staged": "^15",
    "prettier": "^3",
    "turbo": "^2.0.0",
    "typescript-eslint": "^8"
  }
}
