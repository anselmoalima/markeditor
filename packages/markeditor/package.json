{
  "name": "markeditor",
  "version": "0.0.9",
  "description": "Configurable React Markdown editor component with Monaco + unified pipeline",
  "type": "module",
  "license": "MIT",
  "sideEffects": [
    "**/*.css"
  ],
  "engines": {
    "node": ">=18.18"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles": {
      "style": "./dist/styles.css",
      "default": "./dist/styles.css"
    },
    "./plugins": {
      "import": {
        "types": "./dist/plugins/index.d.ts",
        "default": "./dist/plugins/index.mjs"
      },
      "require": {
        "types": "./dist/plugins/index.d.cts",
        "default": "./dist/plugins/index.cjs"
      }
    },
    "./plugins/*": {
      "import": {
        "types": "./dist/plugins/*.d.ts",
        "default": "./dist/plugins/*.mjs"
      },
      "require": {
        "types": "./dist/plugins/*.d.cts",
        "default": "./dist/plugins/*.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.16.4",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "expect-type": "^1.3.0",
    "jsdom": "^26.0.0",
    "publint": "^0.3.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "size-limit": "^12.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "scripts": {
    "build": "tsup && node -e \"const{copyFileSync,mkdirSync}=require('node:fs');mkdirSync('dist',{recursive:true});copyFileSync('src/styles/index.css','dist/styles.css')\"",
    "typecheck": "tsc --noEmit",
    "typecheck:types-test": "tsc --noEmit -p tsconfig.types-test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "coverage": "vitest run --coverage",
    "size": "size-limit --config size-limit.json",
    "publint": "publint",
    "attw": "attw --pack . --ignore-rules no-resolution --exclude-entrypoints ./styles",
    "lint": "eslint . --max-warnings 0",
    "prepublishOnly": "pnpm run build && pnpm run test && pnpm run typecheck && pnpm run lint && pnpm run publint && pnpm run attw && pnpm run size"
  }
}
