{
  "name": "bob-editor",
  "version": "1.0.0",
  "description": "Fully-featured React Markdown editor with Monaco, GFM, math, Mermaid, and plugin system",
  "license": "MIT",
  "author": "anselmodev",
  "keywords": [
    "markdown",
    "editor",
    "react",
    "monaco",
    "gfm",
    "math",
    "mermaid",
    "plugin"
  ],
  "engines": {
    "node": ">=18"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles": "./dist/styles.css",
    "./styles.css": "./dist/styles.css",
    "./plugins": {
      "import": {
        "types": "./dist/plugins/index.d.ts",
        "default": "./dist/plugins/index.js"
      },
      "require": {
        "types": "./dist/plugins/index.d.cts",
        "default": "./dist/plugins/index.cjs"
      }
    },
    "./plugins/emoji": {
      "import": {
        "types": "./dist/plugins/emoji.d.ts",
        "default": "./dist/plugins/emoji.js"
      },
      "require": {
        "types": "./dist/plugins/emoji.d.cts",
        "default": "./dist/plugins/emoji.cjs"
      }
    },
    "./plugins/mentions": {
      "import": {
        "types": "./dist/plugins/mentions.d.ts",
        "default": "./dist/plugins/mentions.js"
      },
      "require": {
        "types": "./dist/plugins/mentions.d.cts",
        "default": "./dist/plugins/mentions.cjs"
      }
    },
    "./plugins/wordCount": {
      "import": {
        "types": "./dist/plugins/wordCount.d.ts",
        "default": "./dist/plugins/wordCount.js"
      },
      "require": {
        "types": "./dist/plugins/wordCount.d.cts",
        "default": "./dist/plugins/wordCount.cjs"
      }
    },
    "./plugins/tableOfContents": {
      "import": {
        "types": "./dist/plugins/tableOfContents.d.ts",
        "default": "./dist/plugins/tableOfContents.js"
      },
      "require": {
        "types": "./dist/plugins/tableOfContents.d.cts",
        "default": "./dist/plugins/tableOfContents.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.17.4",
    "@size-limit/preset-small-lib": "^11.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/hast": "^3.0.4",
    "@types/jest-axe": "^3.5.9",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.1.1",
    "publint": "^0.3.0",
    "react": "^18",
    "react-dom": "^18",
    "size-limit": "^11.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:types": "vitest --typecheck",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "size": "size-limit --config size-limit.json",
    "publint": "publint .",
    "attw": "node scripts/check-types.mjs",
    "prepublishOnly": "pnpm build && pnpm test && pnpm typecheck && pnpm lint && pnpm publint && pnpm attw && pnpm size"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6",
    "hast-util-to-html": "^9.0.5",
    "highlight.js": "^11.11.1",
    "katex": "^0.17.0",
    "mermaid": "^11.15.0",
    "monaco-editor": "^0.55.1",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-react": "^8.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  }
}
